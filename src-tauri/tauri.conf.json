{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "QuickStack",
  "version": "0.1.0",
  "identifier": "com.quickstack.app",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "QuickStack",
        "width": 1100,
        "height": 720,
        "minWidth": 680,
        "minHeight": 500,
        "decorations": true,
        "transparent": false,
        "resizable": true,
        "center": true,
        "visible": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
